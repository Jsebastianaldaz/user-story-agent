# ─────────────────────────────────────────────
# Anthropic
# ─────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─────────────────────────────────────────────
# Atlassian — Confluence
# ─────────────────────────────────────────────
CONFLUENCE_DOMAIN=your-domain.atlassian.net
CONFLUENCE_EMAIL=your_email@company.com
CONFLUENCE_API_TOKEN=your_confluence_api_token_here
CONFLUENCE_CLOUD_ID=your_cloud_id_here
CONFLUENCE_SPACE_KEY=EDP

# ─────────────────────────────────────────────
# Atlassian — Jira
# ─────────────────────────────────────────────
JIRA_DOMAIN=your-domain.atlassian.net
JIRA_EMAIL=your_email@company.com
JIRA_API_TOKEN=your_jira_api_token_here
JIRA_PROJECT_KEY=EDP
JIRA_BOARD_ID=your_board_id_here

# ─────────────────────────────────────────────
# Confluence Page IDs (optional defaults)
# ─────────────────────────────────────────────
CONFLUENCE_PAGE_ID=your_spec_page_id_here
